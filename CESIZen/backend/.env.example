# ── Serveur ──────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Base de données MySQL ────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=cesizen

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_very_long_random_secret_key_256bits
JWT_EXPIRES_IN=24h

# ── Tests ────────────────────────────────────────────────────
DB_NAME_TEST=cesizen_test
